---
import '~/styles/shared.css';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'list' | 'characters' | 'scenes';
}

const {
  title = '魔法学院 · 睡前有声绘本',
  description = '6 岁小橘子口述的睡前有声绘本系列,温柔、有趣、充满想象力。',
  active = 'home',
} = Astro.props;

const navItems = [
  { id: 'home', label: '首页', href: '/home' },
  { id: 'list', label: '故事列表', href: '/story-list' },
  { id: 'characters', label: '人物图鉴', href: '/characters' },
  { id: 'scenes', label: '场景介绍', href: '/scenes' },
] as const;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#f5ecd6" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo/magic-academy-logo-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/logo/magic-academy-logo-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="mobile-web-app-capable" content="yes" />
  </head>
  <body>
    <header class="top-nav" data-od-id="top-nav">
      <a class="brand" href="/home">
        <span class="logo" aria-hidden="true">
          <img src="/logo/magic-academy-logo-64.png" alt="魔法学院" width="40" height="40" />
        </span>
        <span>魔法学院</span>
      </a>
      <nav>
        {navItems.map((it) => (
          <a href={it.href} class={it.id === active ? 'is-active' : ''} aria-current={it.id === active ? 'page' : undefined}>
            {it.label}
          </a>
        ))}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      魔法学院 · 创意来自 6 岁小橘子 · <span class="star">★</span> 温柔睡前陪伴<br/>
      <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener" style="font-size: 12px;">CC BY-NC-SA 4.0</a>
    </footer>

    <script>
      // 客户端运行时校正 nav 高亮(处理 Cloudflare Pages 自动追加尾 / 的情况)
      const pathname = location.pathname.replace(/\/+$/, '') || '/';
      document.querySelectorAll<HTMLAnchorElement>('.top-nav nav a').forEach((a) => {
        const href = (a.getAttribute('href') || '').replace(/\/+$/, '') || '/';
          const navMap: Record<string, string> = {
            '/home': 'home',
            '/story-list': 'list',
            '/characters': 'characters',
            '/scenes': 'scenes',
            '/': 'home',
          };
        const id = navMap[href];
        if (id && (pathname === href || (href !== '/' && pathname.startsWith(href + '/')) || (href === '/' && pathname === '/'))) {
          a.classList.add('is-active');
          a.setAttribute('aria-current', 'page');
        }
      });
    </script>
  </body>
</html>
